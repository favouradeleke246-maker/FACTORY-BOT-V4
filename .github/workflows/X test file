name: Test Buffer

on: workflow_dispatch

jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - name: Test Buffer API
        env:
          BUFFER_TOKEN: ${{ secrets.BUFFER_ACCESS_TOKEN }}
        run: |
          curl -X GET "https://api.bufferapp.com/1/profiles.json" \
            -H "Authorization: Bearer $BUFFER_TOKEN"
